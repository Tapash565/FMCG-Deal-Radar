# All four are OPTIONAL for a read-only demo — the app falls back to the
# committed seed at data/snapshot.json when they're absent.
# They are REQUIRED for live refresh. See docs/architecture.md#deployment.

# Groq — classify/extract (llama-3.1-8b-instant), newsletter (llama-3.3-70b-versatile)
GROQ_API_KEY=

# HuggingFace Inference API — dedup embeddings (all-MiniLM-L6-v2)
HF_API_TOKEN=

# Vercel Blob — live snapshot persistence
BLOB_READ_WRITE_TOKEN=

# Shared secret guarding the daily cron route
CRON_SECRET=
